layout {
  default_tab_template {
    // the default zellij tab-bar and status bar plugins
    pane size=1 borderless=true {
        plugin location="zellij:tab-bar"
    }
    children
    pane size=2 borderless=true {
        plugin location="zellij:status-bar"
    }
  }
  tab name="agent-teams" {
  pane split_direction="vertical" {
    pane {
      name "sei"
      command "claude_instruction"
      args "--instruction" "~/.config/teams/instruction_leader.md" "--worktree" "team-member/sei"
      size "30%"
    }
    pane split_direction="horizontal" {
      pane {
        name "shin"
        command "claude_instruction"
        args "--instruction" "Read ~/.config/teams/instruction_member.md and understand your role." "--worktree" "team-member/shin"
      }
      pane {
        name "ouhon"
        command "claude_instruction"
        args "--instruction" "Read ~/.config/teams/instruction_member.md and understand your role." "--worktree" "team-member/ouhon"
      }
      pane {
        name "mouten"
        command "claude_instruction"
        args "--instruction" "Read ~/.config/teams/instruction_member.md and understand your role." "--worktree" "team-member/mouten"
      }
    }
  }
  }
  tab split_direction="vertical" name="review" {
    pane name="review" {
      cwd "review"
    }
    pane {
      name "review claude"
      command "claude_instruction"
      args "--instruction" "" "--worktree" "review"
    }
  }
}
